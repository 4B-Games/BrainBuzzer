# BrainBuzzer – Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.
# .env wird NICHT in Git eingecheckt.

# ── Supabase ──────────────────────────────────────────────────────
# Zu finden in: Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Auf true setzen, sobald Supabase aktiv ist.
# Danach Imports in allen Services von './dataService' auf
# './dataService.supabase' und von './authService' auf
# './authService.supabase' ändern.
VITE_USE_SUPABASE=false
